# ─────────────────────────────────────────────────────────────
# SovereignWatch — environment configuration
# Copy to .env and fill in real values before running docker compose.
# ─────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
DB_PASSWORD=change_me_please_really
DATABASE_URL=postgresql://sw:change_me_please_really@db:5432/sovereignwatch

# ── Webhooks (change-detection -> API) ──────────────────────
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=replace_with_random_hex_32

# ── Admin panel ─────────────────────────────────────────────
# Admin access is "signed-in user with users.is_admin=true" — flipped
# manually in psql on a per-account basis:
#   UPDATE users SET is_admin = true WHERE email = 'you@example.com';
# No environment variable gates the admin surface; if no user has
# is_admin=true, the panel is simply inaccessible. Requires JWT_SECRET
# + SMTP below to work (same magic-link flow end-users sign in with).

# ── End-user accounts (magic-link auth) ─────────────────────
# Signing key for end-user session JWTs. Rotate to force-logout all
# users. Unset → /api/v1/auth/* + /api/v1/me/* return 503.
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_random_hex_32

# Public URL the frontend is reachable at. Used to build magic-link
# URLs in outgoing emails. In prod: https://canadianpoliticaldata.ca
PUBLIC_SITE_URL=http://localhost:5173

# ── SMTP (magic-link + alert digests) ───────────────────────
# Proton submission: smtp.protonmail.ch:587, STARTTLS, per-address
# submission token (NOT your Proton account password). Create the token
# in the Proton admin console against a verified custom-domain sender.
# Leave unset in dev → emails are logged to server stdout instead.
SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ── Admin jobs worker ───────────────────────────────────────
JOBS_POLL_INTERVAL=5
JOBS_DEFAULT_TIMEOUT=7200

# ── API ─────────────────────────────────────────────────────
API_PORT=3000
API_HOST=0.0.0.0
API_LOG_LEVEL=info
# Allowlisted origin for browser requests that carry the session
# cookie. Single origin or a comma-separated list. Never "*" in
# production: with credentials: true, browsers reject wildcard
# responses anyway, but leaving it "*" is a signal that nothing is
# locked down. Dev default is the Vite server; prod is the public
# site.
API_CORS_ORIGIN=https://canadianpoliticaldata.ca

# ── Frontend ────────────────────────────────────────────────
# Public URL the browser will call. In docker compose it goes through nginx.
VITE_API_BASE_URL=/api/v1

# ── Scanner ─────────────────────────────────────────────────
SCANNER_CONCURRENCY=16
SCANNER_HTTP_TIMEOUT=15
SCANNER_DNS_TIMEOUT=5
SCANNER_USER_AGENT=SovereignWatchBot/1.0 (+https://sovereignwatch.ca)
GEOIP_CITY_PATH=/data/GeoLite2-City.mmdb
GEOIP_ASN_PATH=/data/GeoLite2-ASN.mmdb

# ── Open North ──────────────────────────────────────────────
OPENNORTH_BASE=https://represent.opennorth.ca

# ── Anthropic API (Tier-3 socials backfill — sole carve-out) ────
# Used by exactly one place: the agent-missing-socials scanner command
# (services/scanner/src/socials_agent.py). Every other LLM call in the
# system goes through OpenRouter. This carve-out exists because the
# command relies on Anthropic's server-side web_search_20250305 tool,
# which OpenRouter's chat-completions proxy does not expose. Uses
# claude-sonnet-4-6. Typical cost: ~$1-2 per full residual sweep.
# Unset → agent-missing-socials aborts cleanly; nothing else breaks.
# Get a key at https://console.anthropic.com/ and paste below.
ANTHROPIC_API_KEY=

# ── OpenRouter (model serving for everything except the carve-out) ──
# Powers AI contradictions on /search and premium-report generation on
# /reports. Unset OPENROUTER_API_KEY → both features disabled; the
# /search "Analyze for contradictions" button greys out and the
# /reports "Full report" button greys out. The configured model id is
# surfaced to the consent modal verbatim — users consent to a specific
# third party — and re-prompts whenever you swap the model.
# Get a key at https://openrouter.ai/settings/keys and paste below.
OPENROUTER_API_KEY=

# ── OpenRouter model selection (per feature) ────────────────
# Any model id from https://openrouter.ai/models works in either slot.
# Defaults are conservative; bump as you like.
#   Free-tier examples: nvidia/nemotron-3-super-120b-a12b:free,
#                       qwen/qwen-2.5-72b-instruct:free
#   Paid examples:      anthropic/claude-sonnet-4.6,
#                       openai/gpt-4o-mini, google/gemini-2.5-pro
# Note: OPENROUTER_MODEL (no _CONTRADICTIONS_ suffix) is the legacy
# alias for OPENROUTER_CONTRADICTIONS_MODEL — still accepted, prints a
# one-line deprecation warning at API boot.
OPENROUTER_CONTRADICTIONS_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_REPORT_MODEL=anthropic/claude-sonnet-4.6

# OpenRouter transport / branding (rarely changed).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://canadianpoliticaldata.ca
OPENROUTER_APP_NAME=Canadian Political Data
OPENROUTER_TIMEOUT_MS=30000

# ── Stripe billing rail (premium reports) ──────────────────
# Powers one-time credit-pack purchases on /account/credits. Users
# spend credits on premium features (starting with phase-1b "full
# report" generation). Unset STRIPE_SECRET_KEY → the buy-credits UI
# hides its purchase buttons and POST /me/credits/checkout returns
# 503. STRIPE_WEBHOOK_SECRET is required for POST /webhooks/stripe
# to accept events (fail-closed on missing secret, not fail-open).
#
# Setup:
#   1. Create a Stripe account and a restricted secret key (not the
#      publishable one).
#   2. In the Stripe dashboard, create three one-time products (NOT
#      subscriptions) for the credit packs, copy the price IDs.
#   3. After deploying the webhook route, register its URL in Stripe
#      (`/webhooks/stripe`) and paste the signing secret below.
#
# Get keys at https://dashboard.stripe.com/apikeys (start in test mode).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_CREDIT_PACK_SMALL=
STRIPE_PRICE_ID_CREDIT_PACK_MEDIUM=
STRIPE_PRICE_ID_CREDIT_PACK_LARGE=
# Optional overrides. Default to ${PUBLIC_SITE_URL}/account/credits?purchase=success|cancel.
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# ── Stripe Tax (Canadian GST/HST/PST) ──────────────────────
# Runtime mirror of the Stripe-dashboard Tax switch. Setting this to
# `true` makes every Checkout Session opt into automatic_tax — Stripe
# computes Canadian GST/HST/PST based on the buyer's billing address
# and adds it on top of the pack price. The credits page renders a
# "Prices are exclusive of tax" disclosure when this is on.
#
# DO NOT enable until you have completed the dashboard activation:
#   1. Settings → Tax → Activate Stripe Tax
#   2. Add your Canadian tax registration (GST/HST number + originating
#      address, plus any provincial PST/QST registrations you hold)
#   3. Tax → Tax codes → assign each credit-pack Price a tax code
#      (e.g. txcd_10000000 "General — Services" or a digital-services
#      code if you've decided that's the right classification)
#   4. Decide on Tax Reporting export cadence
# Flipping this flag before (1)–(3) will make every Checkout Session
# 400 immediately. See docs/plans/premium-reports.md § Stripe Tax.
STRIPE_TAX_ENABLED=false

# ── Correction rewards ─────────────────────────────────────
# Credits granted when an admin transitions a signed-in user's
# correction_submissions row into status='applied'. Anonymous
# corrections (user_id IS NULL) earn nothing. Set to 0 to disable
# the reward entirely without removing the code path.
CORRECTION_REWARD_CREDITS=10

# ── Premium reports (phase 1b) ──────────────────────────────
# Paid LLM map-reduce that reads every matching chunk for a politician
# on a queried topic. Distinct from the free-tier contradictions flow.
# The model itself is set above in the OpenRouter model-selection block
# (OPENROUTER_REPORT_MODEL); knobs below shape worker behaviour and
# cost without rebuilds.
OPENROUTER_REPORT_TIMEOUT_MS=120000

# Cost formula (estimated_credits = base + ceil(min(chunks, max)/bucket_size) * per_bucket).
# Defaults target ~$1–$3.50 in credit value per report at the small-pack
# rate. Adjust without rebuilds — both api and reports-worker re-read
# these on restart and must agree. Setting per-bucket to 0 makes
# reports flat-priced; setting base to 0 charges purely by volume.
REPORT_BASE_COST_CREDITS=5
REPORT_PER_CHUNK_BUCKET_COST=1
REPORT_BUCKET_SIZE=10
REPORT_MAX_CHUNKS=300
REPORT_HNSW_EF_SEARCH=1000

# Per-tier daily caps on report submissions. unlimited tier bypasses;
# suspended tier is enforced upstream by requireUser.
REPORTS_RATE_LIMIT_DEFAULT_PER_DAY=5
REPORTS_RATE_LIMIT_EXTENDED_PER_DAY=20

# reports-worker poll interval. Reports are user-visible so this is
# tighter than the alerts-worker's 300s (digests are background).
REPORTS_POLL_INTERVAL=5

# ── Backups (scripts/backup-database.sh) ────────────────────
# Daily Postgres backup tuning. The script reads these from .env;
# any value also exported in the process environment wins (cron line
# overrides for one-off runs). Defaults in the script match what's
# shown here, so unset == default.
#
# BACKUP_COMPRESS_LEVEL: zstd level (1..19) used to compact older
# dumps. 3 is the zstd default — fast, ~5–10% larger than -19. -19 is
# CPU-saturating on a multi-core box for hours; avoid on a workstation.
# BACKUP_PARALLEL_JOBS: pg_dump -j fan-out for the directory dump.
# BACKUP_RETENTION: total dumps kept (1 uncompressed + N-1 compacted).
# BACKUP_DEST: target directory; must exist and be writable.
BACKUP_COMPRESS_LEVEL=3
BACKUP_PARALLEL_JOBS=8
BACKUP_RETENTION=7
BACKUP_DEST=/media/bunker-admin/Internal/canadian-political-data-backups

# ── Apify scrape worker ─────────────────────────────────────
# Paid user-facing politician-monitoring feature. The scanner-side
# scrape_worker pulls social posts from Apify (+ free direct APIs for
# Bluesky/Mastodon) on a cadence and debits user credits per refresh.
# See docs/plans/apify-social-deep-enrichment.md and the user-billed
# overlay plan in plans/okay-lets-do-purring-hearth.md.
#
# APIFY_API_TOKEN: required for any Apify actor call. Generate at
#   https://console.apify.com/settings/integrations
APIFY_API_TOKEN=

# Per-scrape depth caps. Defaults are dev-safe (small, cheap); bump
# to production values (~100) once the worker is proven and the
# Apify plan tier is sized for the load.
SCRAPE_TWITTER_TWEETS_PER_RUN=10
SCRAPE_INSTAGRAM_POSTS_PER_RUN=10
SCRAPE_BLUESKY_POSTS_PER_RUN=20
SCRAPE_MASTODON_POSTS_PER_RUN=20

# Platform-level circuit breaker: stops dequeuing once today's
# cumulative Apify cost_usd hits this cap. Resets at UTC midnight.
SCRAPE_DAILY_USD_CAP=5

# Dispatcher loop tick (seconds). Worker loop drains queued jobs
# at its own pace; this only governs how often we look for newly
# due saved_searches.
SCRAPE_DISPATCH_INTERVAL=60

# ── Uptime Kuma ─────────────────────────────────────────────
KUMA_PORT=3001

# ── Deployment ──────────────────────────────────────────────
PUBLIC_HOST=sovereignwatch.ca

# ── Pangolin Newt tunnel ────────────────────────────────────
PANGOLIN_ENDPOINT=https://pangolin.bnkserve.org
NEWT_ID=
NEWT_SECRET=
